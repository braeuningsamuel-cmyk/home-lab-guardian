# Home Lab Guardian - Environment Variables
# Copy this file to .env and fill in the values

# Application
VITE_APP_NAME=Atlas.Lab
VITE_APP_VERSION=1.0.0

# API endpoint for homelab backend
# Leave empty to use built-in mock data
VITE_API_BASE_URL=

# Default remote host (optional)
# Format: user@hostname or ssh://user@hostname:port
VITE_DEFAULT_HOST=

# Authentication token (if backend requires it)
VITE_API_TOKEN=

# Feature flags
VITE_ENABLE_TERMINAL=true
VITE_ENABLE_FILE_EDITOR=true
VITE_ENABLE_PACKAGE_MANAGER=true